<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="MultiBrowserTesting" parallel="tests">
  <test name="ChromeTest">
  <parameter name="browser" value="chrome"></parameter>
    <classes>
      <class name="testScript.ManageCategoryTest"/>
      <class name="testScript.ManageNewsTest"/>
      <class name="testScript.LogoutTest"/>
      <class name="testScript.LoginTest"/>
      <class name="testScript.AdminUsersTest"/>
      <class name="testScript.ManageCODTest"/>
       <class name="testScript.ManageLocationTest"/>
    </classes>
  </test> <!-- Test -->
  <test name="FireFoxTest">
  <parameter name="browser" value="firefox"></parameter>
  <classes>
      <class name="testScript.ManageCategoryTest"/>
      <class name="testScript.ManageNewsTest"/>
      <class name="testScript.LogoutTest"/>
      <class name="testScript.LoginTest"/>
      <class name="testScript.AdminUsersTest"/>
      <class name="testScript.ManageCODTest"/>
       <class name="testScript.ManageLocationTest"/>
    </classes>
  </test>
</suite> <!-- Suite -->
